# EstateGuard — host ports (chosen to avoid common dev conflicts: 3000, 5432, 6379, 8000)
# Change these if 19000-19003 are taken on your machine.

EG_WEB_PORT=19000
EG_API_PORT=19001
EG_POSTGRES_PORT=19002
EG_REDIS_PORT=19003

# Local / docker-compose host URLs (used by web + Makefile)
NEXT_PUBLIC_API_URL=http://localhost:19001
CORS_ORIGINS=http://localhost:19000

# Database (host machine → use EG_POSTGRES_PORT)
DATABASE_URL=postgresql+asyncpg://estateguard:estateguard@localhost:19002/estateguard
DATABASE_URL_SYNC=postgresql://estateguard:estateguard@localhost:19002/estateguard
REDIS_URL=redis://localhost:19003/0

# Inside Docker network the API uses service names (do not change unless you know why)
DOCKER_DATABASE_URL=postgresql+asyncpg://estateguard:estateguard@postgres:5432/estateguard
API_INTERNAL_URL=http://api:8000

SECRET_KEY=dev-secret-change-in-production
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
